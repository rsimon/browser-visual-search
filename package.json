{
  "name": "browser-visual-search",
  "version": "0.1.0",
  "description": "In-browser visual search powered by FastSAM, CLIP and onnxruntime-web.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "vite",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "peerDependencies": {
    "onnxruntime-web": "^1.24.3"
  },
  "devDependencies": {
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "onnxruntime-web": "^1.24.3",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "visual-search",
    "clip",
    "fastsam",
    "onnx",
    "browser",
    "image-segmentation",
    "embeddings"
  ],
  "license": "MIT"
}
